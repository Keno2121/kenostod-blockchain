modules = ["nodejs-20", "java-graalvm22.3", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["javascript_database:1.0.0", "javascript_openai_ai_integrations:1.0.0", "stripe:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Kenostod Blockchain Server"

[[workflows.workflow]]
name = "Kenostod Blockchain Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server.js"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 34573
externalPort = 3003

[[ports]]
localPort = 35713
externalPort = 5173

[[ports]]
localPort = 37187
externalPort = 4200

[[ports]]
localPort = 38379
externalPort = 3001

[[ports]]
localPort = 40231
externalPort = 80

[[ports]]
localPort = 44207
externalPort = 3002

[[ports]]
localPort = 46159
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["node", "server.js"]
