# Bot wallet — run generate_bot_wallet.py to auto-fill these
BOT_PRIVATE_KEY=0x...
BOT_ADDRESS=0x...

# Network: testnet or mainnet
NETWORK=testnet

# Risk controls
MIN_SPREAD_PCT=0.6
MIN_PROFIT_USD=0.25
MAX_BNB_PER_TRADE=0.1
MAX_GAS_GWEI=10

# Optional: FlashOrbBot contract address (filled after deploy)
FLASH_ORB_CONTRACT=

# Telegram alerts — get chat ID by visiting:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates after messaging your bot
TELEGRAM_BOT_TOKEN=   # already set in Replit secrets — copy it here for local .env
TELEGRAM_CHAT_ID=     # your personal Telegram chat ID (a number like 123456789)
