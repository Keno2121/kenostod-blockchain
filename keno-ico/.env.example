# ========================================
# KENO ICO - Environment Configuration
# ========================================

# DEPLOYMENT WALLET (REQUIRED)
# Get your private key from MetaMask:
# 1. Open MetaMask → Click 3 dots → Account details → Export private key
# 2. Paste the key below (WITHOUT the 0x prefix is fine)
# ⚠️  NEVER share this or commit it to GitHub!
PRIVATE_KEY=your_private_key_here_keep_secret

# NETWORK CONFIGURATION
# For testing: Use BSC Testnet (FREE!)
# For production: Use BSC Mainnet ($5-10 deployment cost)
RPC_URL=https://bsc-dataseed.binance.org/
NETWORK=bsc

# WALLET ADDRESSES (Optional - defaults to deployer address)
# You can use separate wallets for each purpose
TEAM_WALLET=
TREASURY_WALLET=
LIQUIDITY_WALLET=

# DEPLOYED CONTRACT ADDRESSES (After deployment)
# Run deploy script first, then fill these in
KENO_TOKEN_ADDRESS=
PRESALE_CONTRACT_ADDRESS=

# BLOCK EXPLORER API KEYS (For contract verification - optional)
BSCSCAN_API_KEY=
ETHERSCAN_API_KEY=

# ========================================
# QUICK START GUIDE
# ========================================

# STEP 1: Get testnet BNB (FREE!)
# Visit: https://testnet.binance.org/faucet-smart
# Enter your MetaMask address
# Receive free testnet BNB for testing

# STEP 2: Add your private key above (KEEP SECRET!)

# STEP 3: Test on BSC Testnet
# npx hardhat run scripts/deploy.js --network bscTestnet

# STEP 4: When ready, deploy to mainnet
# npx hardhat run scripts/deploy.js --network bsc

# ========================================
# COST ESTIMATES
# ========================================

# BSC Testnet: FREE (use testnet BNB from faucet)
# BSC Mainnet: ~$5-10 total (KENO + Presale contracts)
# Ethereum Mainnet: ~$200-400 (NOT recommended - high gas fees)

# ========================================
# SECURITY NOTES
# ========================================

# ✅ DO: Keep this file secure and private
# ✅ DO: Add .env to .gitignore (already done)
# ✅ DO: Test on testnet before mainnet
# ✅ DO: Verify contracts on BSCScan after deployment

# ❌ DON'T: Share your private key with anyone
# ❌ DON'T: Commit .env to GitHub
# ❌ DON'T: Use the same wallet for large amounts
# ❌ DON'T: Skip testnet testing
