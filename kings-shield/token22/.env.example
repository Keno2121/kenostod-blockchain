# King's Shield Token-2022 — Environment Config
# ================================================
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# ── Mint Authority ────────────────────────────────
# Generate with: node generate-wallet.js
SHIELD_MINT_AUTHORITY_PUBKEY=
SHIELD_MINT_AUTHORITY_PRIVKEY=   # base58 private key

# ── Deployed Mint Address (filled after deploy) ───
SHIELD_MINT_ADDRESS=

# ── Cluster ───────────────────────────────────────
SOLANA_CLUSTER=devnet   # devnet | mainnet-beta

# ── Allocation Recipient Wallets ──────────────────
# Set Solana wallet addresses for each allocation bucket
SHIELD_LIQUIDITY_PRESALE_WALLET=    # 40% — Raydium LP + presale
SHIELD_ACADEMY_TREASURY_WALLET=     # 20% — Kenostod Academy Treasury
SHIELD_MARKETING_WALLET=            # 15% — Marketing & Global Expansion
SHIELD_ECOSYSTEM_WALLET=            # 15% — Ecosystem Rewards & Grants
SHIELD_CORETEAM_WALLET=             # 10% — Core Team (617.4-day lock)

# ── Aegis Tax Distribution (6.174% total — Kaprekar's Constant) ──────────
# Every transfer splits 3 ways automatically via collect-aegis-tax.ts:
SHIELD_HOLDER_YIELD_WALLET=         # 3.000% → redistributed to all SHIELD holders
SHIELD_AUTO_LIQ_WALLET=             # 2.000% → Raydium SHIELD/SOL auto-liquidity
SHIELD_BRIDGE_WALLET=               # 1.174% → Kenostod Bridge → BSC KENO buy+burn

# ── Cross-chain (used by aegis_relay.py) ─────────
KENO_AUTOBURN_BSC=                  # KENOAutoBurn contract address on BSC
AEGIS_TREASURY_WALLET=              # Solana wallet holding collected Aegis Tax SOL
AEGIS_BURN_THRESHOLD_SOL=1.0        # trigger KENO burn when treasury holds this much SOL
AEGIS_POLL_INTERVAL=300             # check every 300 seconds (5 minutes)
