    "esbuild": "^0.27.3",
    "ethers": "^6.15.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "openai": "^6.9.1",
    "pg": "^8.16.3",
    "stripe": "^19.3.1",
    "stripe-replit-sync": "^0.0.12"
  },
