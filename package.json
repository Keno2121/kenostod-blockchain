{
  "name": "kenostod-blockchain",
  "version": "1.0.0",
  "description": "Kenostod - A custom blockchain with native token",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "echo 'No build step required - serving static files'",
    "mine": "node cli.js mine",
    "balance": "node cli.js balance",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:build:debug": "npx cap sync android && cd android && ./gradlew assembleDebug",
    "cap:build:release": "npx cap sync android && cd android && ./gradlew bundleRelease"
  },
  "keywords": [
    "blockchain",
    "cryptocurrency",
    "kenostod"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@coinbase/wallet-sdk": "^4.3.7",
    "@openzeppelin/contracts": "^5.4.0",
    "@paypal/checkout-server-sdk": "^1.0.3",
    "@paypal/paypal-server-sdk": "^1.1.0",
    "@walletconnect/ethereum-provider": "^2.23.5",
    "binance": "^3.1.2",
    "cordova-plugin-purchase": "^13.12.1",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.3.1",
    "elliptic": "^6.6.1",
    "esbuild": "^0.27.3",
    "ethers": "^6.15.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "openai": "^6.9.1",
    "pg": "^8.16.3",
    "puppeteer-core": "^24.37.3",
    "stripe": "^19.3.1",
    "stripe-replit-sync": "^0.0.12"
  },
  "overrides": {
    "axios": ">=1.13.5",
    "immutable": ">=4.3.8",
    "minimatch": ">=10.2.3",
    "serialize-javascript": ">=7.0.3",
    "fast-xml-parser": ">=4.5.4",
    "undici": ">=6.23.0",
    "cookie": ">=0.7.0",
    "lodash": ">=4.17.22",
    "bn.js": ">=4.12.3",
    "ethereum-cryptography": ">=1.0.0",
    "tmp": ">=0.2.4"
  }
}
