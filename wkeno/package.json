{
  "name": "wkeno-deployment",
  "version": "1.0.0",
  "description": "Wrapped KENO (wKENO) deployment — Base and Polygon",
  "scripts": {
    "compile": "hardhat compile",
    "deploy:base": "hardhat run scripts/deploy-wkeno-base.js --network base",
    "deploy:base-testnet": "hardhat run scripts/deploy-wkeno-base.js --network baseSepolia",
    "deploy:polygon": "hardhat run scripts/deploy-wkeno-polygon.js --network polygon",
    "deploy:polygon-testnet": "hardhat run scripts/deploy-wkeno-polygon.js --network polygonAmoy",
    "verify:base": "hardhat verify --network base",
    "verify:polygon": "hardhat verify --network polygon"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "hh2",
    "dotenv": "^17.3.1",
    "hardhat": "^2.22.0",
    "@openzeppelin/contracts": "^5.0.0"
  }
}
